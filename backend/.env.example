APP_NAME=Market Intelligence API
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/market_intelligence
REDIS_URL=rediss://default:<upstash-token>@<upstash-host>:6379?ssl_cert_reqs=required
UPSTASH_REDIS_REST_URL=https://<upstash-host>
UPSTASH_REDIS_REST_TOKEN=<upstash-rest-token>
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
AI_AGENT_ENABLED=false
AI_AGENT_BASE_URL=http://localhost:8001
AI_AGENT_ANALYZE_PATH=/analyze
AI_AGENT_TIMEOUT_SECONDS=60
DB_ECHO=false
CORS_ORIGINS=*
JOB_STATUS_TTL_SECONDS=86400
INSIGHTS_CACHE_TTL_SECONDS=300
LOG_LEVEL=INFO
