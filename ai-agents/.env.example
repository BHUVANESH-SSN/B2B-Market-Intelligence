# Copy this file to .env and fill in the values you want to use.

# Required if you use Anthropic models in analyst/recommender agents
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional if you want to use OpenAI models instead
OPENAI_API_KEY=your_openai_api_key_here

# Optional if you want to use Groq instead
GROQ_API_KEY=your_groq_api_key_here

# Choose: groq, anthropic, or openai
LLM_PROVIDER=groq

# Model configuration
ANALYST_MODEL=openai/gpt-oss-20b
RECOMMENDER_MODEL=openai/gpt-oss-20b

# Runtime configuration
ENVIRONMENT=development
LOG_LEVEL=INFO
